# ---------- Database ----------
DATABASE_URL=postgres://twotter:twotter@localhost:5432/twotter

# Pool tuning (rule of thumb: 2*CPU + spare; raise with caution — Postgres counts sessions
# too). Leave unset to use defaults (max=30, idle=20s, lifetime=30min, connect_timeout=10s).
# DB_POOL_MAX=30
# DB_POOL_IDLE_TIMEOUT_SEC=20
# DB_POOL_MAX_LIFETIME_SEC=1800
# DB_POOL_CONNECT_TIMEOUT_SEC=10
# Set to "false" when deploying behind PgBouncer in transaction mode.
# DB_PREPARE=true

# ---------- Auth ----------
BETTER_AUTH_SECRET=replace-me-with-32-plus-bytes-of-random
BETTER_AUTH_URL=http://localhost:3001

# Session cookie config (derived from BETTER_AUTH_URL in code; override per env)
AUTH_COOKIE_DOMAIN=localhost
# Comma list; must match the browser tab origin (scheme + host + port). In development the API
# also merges common localhost/127.0.0.1 ports. Use http://127.0.0.1:3000 not localhost if the URL bar shows 127.0.0.1 — they are different origins to the browser.
AUTH_TRUSTED_ORIGINS=http://localhost:3000,http://localhost:3001,http://127.0.0.1:3000,http://127.0.0.1:3001

# ---------- OAuth (sign-in) ----------
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

GITLAB_CLIENT_ID=
GITLAB_CLIENT_SECRET=

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ---------- Connectors (profile-linked GitHub, NOT for login) ----------
# Register a separate GitHub OAuth App at https://github.com/settings/developers
# Authorization callback URL: <BETTER_AUTH_URL>/api/connectors/github/callback
GITHUB_CONNECT_CLIENT_ID=
GITHUB_CONNECT_CLIENT_SECRET=

# 32 random bytes, base64-encoded. Required to enable connectors. Generate with:
#   bun -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
CONNECTORS_ENCRYPTION_KEY=

# GitHub PAT (read-only public_repo scope is enough) used to fetch metadata for the GitHub
# post cards. Optional — without it, GitHub URLs in posts render without the rich card.
GITHUB_UNFURL_TOKEN=

# ---------- Email ----------
EMAIL_FROM="twotter <noreply@localhost>"
EMAIL_PROVIDER=smtp                 # smtp | resend
RESEND_API_KEY=
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASS=

# ---------- Storage (S3-compatible) ----------
S3_ENDPOINT=http://localhost:9000
S3_REGION=auto
S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=minioadmin
S3_BUCKET=twotter-media
S3_PUBLIC_URL=http://localhost:9000/twotter-media
# How long the /api/m/* signing proxy mints S3 GET URLs for (seconds, 60..3600). Default 900
# (15 min) — short enough that leaked URLs expire before most leak vectors find them, long
# enough that a slow page load + image decode finishes before expiry.
# MEDIA_SIGNED_URL_TTL_SEC=900

# ---------- Redis (rate-limit + realtime + cache, added at M2) ----------
REDIS_URL=redis://localhost:6379

# ---------- Web (Vite: only VITE_* is exposed to the client; set these in the env file the web app uses) ----------
VITE_PUBLIC_API_URL=http://localhost:3001
VITE_PUBLIC_APP_NAME=twotter
# Databuddy analytics client ID (from https://app.databuddy.cc). Leave blank to disable.
VITE_PUBLIC_DATABUDDY_CLIENT_ID=
# Databuddy server-side API key (from https://app.databuddy.cc, format: dbdy_xxx). Leave blank to disable.
DATABUDDY_API_KEY=
# Must match VITE_PUBLIC_DATABUDDY_CLIENT_ID so server events are scoped to the same website.
DATABUDDY_WEBSITE_ID=
VITE_PUBLIC_WEB_URL=http://localhost:3000

# ---------- Anti-abuse ----------
TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# ---------- Maintenance / kill switch ----------
# Server: when true, every request (except /healthz and /readyz) gets a 503 with
# `{ error: "maintenance" }`. Toggle + restart to lock down the app at runtime when
# abuse is in progress — no redeploy needed.
# MAINTENANCE_MODE=false
# Optional human-readable message rendered on the client maintenance screen.
# MAINTENANCE_MESSAGE=We're temporarily down for maintenance. Check back shortly.
# Client (build-time): when true, the bundled web app refuses to even hit the network
# and renders the maintenance screen on load. Belt-and-suspenders to keep cached
# clients from hammering the API during incidents — requires a redeploy to flip.
# VITE_PUBLIC_MAINTENANCE_MODE=false

# ---------- Observability ----------
LOG_LEVEL=info
SENTRY_DSN=

# Rate limit caps live in packages/rate-limit/src/limits.ts (BUCKETS).

# ---------- Transport security ----------
# When the API is permanently HTTPS, set ENABLE_HSTS=true to add a 1-year HSTS header with
# includeSubDomains + preload. Once a browser sees this it locks the origin to HTTPS — only
# flip on AFTER you are sure HTTPS is permanent for the domain.
# ENABLE_HSTS=false

# ---------- Connection-token encryption (libsodium master key) ----------
CONNECTOR_TOKEN_KEY=replace-me-with-32-bytes-base64
