{
  "name": "twotter",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "build": "turbo build",
    "dev": "turbo dev",
    "lint": "turbo lint",
    "lint:fix": "turbo lint:fix",
    "format": "turbo format",
    "format:check": "turbo format:check",
    "typecheck": "turbo typecheck",
    "db:push": "bun --env-file=../../.env run --cwd packages/db push",
    "db:studio": "bun --env-file=../../.env run --cwd packages/db studio",
    "services:up": "docker compose up -d",
    "services:down": "docker compose down",
    "playground": "bun run --filter @workspace/playground dev",
    "docs": "cabinet dev --port 4000 --previewPort 4001",
    "docs:build": "cabinet build"
  },
  "devDependencies": {
    "@cabinetdocs/cli": "^0.1.0",
    "@cabinetdocs/core": "^0.1.0",
    "@cabinetdocs/preview-react": "^0.1.0",
    "prettier": "^3.8.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "turbo": "^2.8.17",
    "typescript": "5.9.3"
  },
  "packageManager": "bun@1.3.5",
  "engines": {
    "node": ">=20"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ]
}
